%% =====================================================
%% EVALUATION REPORT DATA MODEL
%% Stored in MongoDB (per-job database)
%% =====================================================

graph LR
    subgraph "EvaluationReport Document"
        R[Report]
        R --> R1[candidateId: UUID]
        R --> R2[jobId: UUID]
        R --> R3[applicationId: UUID]
        R --> R4[score: 0-100]
        R --> R5[status: Accepted/HRReview/Rejected]
        R --> R6[evaluatedAt: DateTime]
        
        R --> SK[skillsAnalysis]
        SK --> SK1[matchedSkills: array]
        SK --> SK2[missingSkills: array]
        SK --> SK3[matchPercentage: int]
        SK --> SK4[details: string]
        
        R --> ED[educationAnalysis]
        ED --> ED1[required: string]
        ED --> ED2[candidate: string]
        ED --> ED3[match: boolean]
        ED --> ED4[score: int]
        
        R --> EX[experienceAnalysis]
        EX --> EX1[requiredYears: int]
        EX --> EX2[candidateYears: int]
        EX --> EX3[relevantExperience: array]
        EX --> EX4[score: int]
        
        R --> SM[summary]
        SM --> SM1[decision: string]
        SM --> SM2[reasoning: string]
        SM --> SM3[strengths: array]
        SM --> SM4[concerns: array]
        
        R --> IQ[interviewQuestions: array]
        IQ --> IQ1[category: string]
        IQ --> IQ2[question: string]
        IQ --> IQ3[difficulty: Easy/Medium/Hard]
        IQ --> IQ4[expectedAnswer: string]
        
        R --> AI[aiMetadata]
        AI --> AI1[model: gemma-3-27b-it]
        AI --> AI2[processingTimeMs: long]
        AI --> AI3[reflectionIterations: int]
    end

