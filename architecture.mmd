%% =====================================================
%% AI EVALUATION PIPELINE SEQUENCE
%% =====================================================

sequenceDiagram
    participant Q as Queue Trigger
    participant AI as AI Agent
    participant LLM as Gemini API
    participant API as .NET API
    participant DB as MongoDB

    Q->>AI: Trigger evaluation request
    AI->>API: Download CV file
    API-->>AI: CV PDF bytes
    
    AI->>AI: Parse CV (PyMuPDF4LLM)
    AI->>LLM: Extract skills from CV
    LLM-->>AI: Skills list
    
    AI->>LLM: Extract skills from job requirements
    LLM-->>AI: Required skills list
    
    AI->>LLM: Analyze skills match
    LLM-->>AI: Skills analysis
    
    AI->>LLM: Analyze education
    LLM-->>AI: Education analysis
    
    AI->>LLM: Analyze experience
    LLM-->>AI: Experience analysis
    
    AI->>AI: Calculate total score
    AI->>AI: Determine status (thresholds)
    
    AI->>LLM: Generate summary
    LLM-->>AI: Summary with reasoning
    
    rect rgb(255, 240, 245)
        Note over AI,LLM: Reflection Loop (up to 2 iterations)
        AI->>LLM: Reflect on evaluation
        LLM-->>AI: Validation result
        AI->>AI: Adjust score if needed
    end
    
    alt Score >= 65 (Not Rejected)
        AI->>LLM: Generate interview questions with expected answers
        LLM-->>AI: 20 interview questions
    end
    
    AI->>API: POST /api/reports (save evaluation)
    API->>DB: Insert report document
    API->>API: Update SQL application status
    API-->>AI: Report saved confirmation

