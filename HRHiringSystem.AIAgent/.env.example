# HRHiring AI Agent Environment Variables

# Google Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TEMPERATURE=0.1

# .NET API Configuration
DOTNET_API_URL=http://localhost:8080

# Azure Blob Storage
AZURE_BLOB_CONNECTION_STRING=your-azure-blob-connection-string

# Scoring Thresholds
SCORE_ACCEPTED_THRESHOLD=80
SCORE_HR_REVIEW_THRESHOLD=65

# RAG / Vector Retrieval
RAG_ENABLED=true
RAG_PERSIST_DIRECTORY=./rag_store
RAG_COLLECTION_PREFIX=job_kb
RAG_TOP_K=4
RAG_MAX_CONTEXT_CHARS=2500
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# App Settings
DEBUG=false
