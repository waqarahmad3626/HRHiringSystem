# TalentLink Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# DATABASE CONFIGURATION
# ============================================

# SQL Server SA Password (required)
# Must meet password policy: 8+ chars, uppercase, lowercase, number/symbol
SQL_SA_PASSWORD=YourStrong@Password123!

# ============================================
# JWT AUTHENTICATION
# ============================================

# JWT Signing Key (required)
# Generate: openssl rand -hex 32
JWT_KEY=your-256-bit-secret-key-minimum-32-characters-long

# JWT Issuer - must match API configuration
JWT_ISSUER=HRHiringSystem.API

# JWT Audience - must match client configuration  
JWT_AUDIENCE=HRHiringSystem.Client

# Token expiration in minutes
JWT_EXPIRES_MINUTES=60

# ============================================
# AZURE BLOB STORAGE
# ============================================

# For local development with Azurite (default):
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;

# For production Azure Storage:
# AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net

# ============================================
# GOOGLE GEMINI AI (REQUIRED)
# ============================================

# Get your API key from: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# Model to use (default: gemma-3-27b-it)
GEMINI_MODEL=gemma-3-27b-it

# ============================================
# AZURE FUNCTIONS
# ============================================

# Shared secret for function authentication
# Generate: openssl rand -hex 16
FUNCTION_API_KEY=your-random-function-api-key

# ============================================
# TEST USER (CREATED ON FIRST STARTUP)
# ============================================
# Email:    test@capstone.com
# Password: Test1234!
# Role:     Admin
# Usage:    Initial setup and system configuration
# Note:     Change this password after first login

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# Scoring thresholds (defaults shown)
# SCORE_ACCEPTED_THRESHOLD=80
# SCORE_HR_REVIEW_THRESHOLD=65

# Enable debug mode for AI Agent
# DEBUG=false

